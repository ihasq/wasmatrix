{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM"],
    "rootDir": "src",
    "outDir": "dist",
    "allowJs": false,
    "checkJs": false,
    "declaration": false,
    "sourceMap": true,
    "inlineSources": true,
    "strict": false,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["assembly", "build", "docs", "node_modules", "test"]
}
