    "build:dist": "deno task build:dist",
    "build:debug": "deno task build:debug",
    "docs:dev": "deno task docs:dev",
    "docs:build": "deno task docs:build",
    "docs:serve": "deno task docs:serve",
    "test": "deno task test",
    "coverage": "deno task coverage",
    "coverage:codecov": "deno task coverage:codecov",
    "test:e2e": "deno task test:e2e",
    "test:e2e:transparency": "deno task test:e2e:transparency",
    "test:e2e:benchmark": "deno task test:e2e:benchmark",
    "benchmark": "deno task benchmark",
    "fmt": "deno task fmt",
    "lint": "deno task lint"
  },
  "engines": {
    "node": ">=18"
  }
