{
  "name": "wasmatrix",
  "version": "0.0.4",
  "description": "SIMD-required WebAssembly matrix operations powered by AssemblyScript",
  "keywords": [
    "wasm",
    "simd",
    "matrix",
    "assemblyscript",
    "linear-algebra"
  ],
  "homepage": "https://github.com/ihasq/wasmatrix#readme",
  "bugs": {
    "url": "https://github.com/ihasq/wasmatrix/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ihasq/wasmatrix.git"
  },
  "license": "MIT",
  "author": "ihasq",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:wasm && npm run build:ts && npm run build:dist",
    "build:wasm": "asc --config asconfig.json --target release",
    "build:ts": "tsc -p tsconfig.json",
    "build:dist": "node scripts/prepare-dist.mjs build/wasmatrix.wasm",
    "build:debug": "asc --config asconfig.json --target debug && npm run build:ts && node scripts/prepare-dist.mjs build/wasmatrix.debug.wasm",
    "docs:dev": "npm --prefix docs run start -- --host 127.0.0.1",
    "test": "npm run build && node --test test/*.test.mjs",
    "coverage": "npm run build && c8 --reporter=text --reporter=lcov node --test test/*.test.mjs",
    "coverage:codecov": "npm run coverage && node scripts/prepare-codecov-lcov.mjs",
    "test:e2e": "npm run build && node --test test/e2e-transparency.test.mjs test/e2e-benchmark.mjs",
    "test:e2e:transparency": "npm run build && node --test test/e2e-transparency.test.mjs",
    "test:e2e:benchmark": "npm run build && node --test test/e2e-benchmark.mjs",
    "benchmark": "npm run test:e2e:benchmark"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "assemblyscript": "^0.28.19",
    "c8": "^11.0.0",
    "typescript": "^5.8.3"
  }
}
